# Service
SERVICE_PORT=8080
LOG_LEVEL=INFO
PRINTER_DRIVER=mock          # mock | ble

# Printer (filled in once the device arrives)
PRINTER_MAC=
PRINTER_WIDTH_PX=384

# LLM (Anthropic Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Weather (Dublin defaults)
WEATHER_LAT=53.35
WEATHER_LON=-6.26
WEATHER_TZ=Europe/Dublin

# Google (Calendar + Gmail share one OAuth client)
GOOGLE_CLIENT_SECRET_PATH=secrets/client_secret.json
GOOGLE_TOKEN_PATH=secrets/google_token.json

# News feeds — overridable; defaults live in src/sources/news.py

# Output
OUTPUT_DIR=output
